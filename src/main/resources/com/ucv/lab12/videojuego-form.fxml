<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.Font?>

<VBox xmlns="http://javafx.com/javafx/21"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.ucv.lab12.controller.VideojuegoFormController"
      spacing="14"
      style="-fx-padding:24; -fx-background-color:white;"
      prefWidth="480">

    <Label fx:id="lblTitulo" text="Videojuego"
           style="-fx-font-size:20; -fx-font-weight:bold; -fx-text-fill:#1565C0;">
        <font><Font size="20.0"/></font>
    </Label>
    <Separator/>

    <GridPane hgap="12" vgap="10">
        <columnConstraints>
            <ColumnConstraints minWidth="110" prefWidth="120" halignment="RIGHT"/>
            <ColumnConstraints hgrow="ALWAYS" minWidth="250"/>
        </columnConstraints>

        <Label text="Nombre: *" style="-fx-font-weight:bold;" GridPane.rowIndex="0" GridPane.columnIndex="0"/>
        <TextField fx:id="txtNombre" promptText="Nombre del juego…" GridPane.rowIndex="0" GridPane.columnIndex="1"/>

        <Label text="Consola: *" style="-fx-font-weight:bold;" GridPane.rowIndex="1" GridPane.columnIndex="0"/>
        <TextField fx:id="txtConsola" promptText="Ej: PC, PS5, Nintendo Switch…" GridPane.rowIndex="1" GridPane.columnIndex="1"/>

        <Label text="Género:" GridPane.rowIndex="2" GridPane.columnIndex="0"/>
        <TextField fx:id="txtGenero" promptText="Ej: Acción, RPG, Deportes…" GridPane.rowIndex="2" GridPane.columnIndex="1"/>

        <Label text="Clasificación:" GridPane.rowIndex="3" GridPane.columnIndex="0"/>
        <TextField fx:id="txtClasificacion" promptText="Ej: Mayores de 14, Todo Público…" GridPane.rowIndex="3" GridPane.columnIndex="1"/>

        <Label text="Distribuidor: *" style="-fx-font-weight:bold;" GridPane.rowIndex="4" GridPane.columnIndex="0"/>
        <ComboBox fx:id="cmbDistribuidor" promptText="Seleccione distribuidor…" maxWidth="Infinity" GridPane.rowIndex="4" GridPane.columnIndex="1"/>

        <Label text="Descripción:" GridPane.rowIndex="5" GridPane.columnIndex="0" GridPane.valignment="TOP"/>
        <TextArea fx:id="txtDescripcion" promptText="Breve descripción del juego…"
                  GridPane.rowIndex="5" GridPane.columnIndex="1" prefHeight="70" wrapText="true"/>
    </GridPane>

    <Label text="(*) Campos obligatorios" style="-fx-font-size:11; -fx-text-fill:#757575;"/>

    <HBox spacing="10" alignment="CENTER_RIGHT">
        <Button fx:id="btnCancelar" text="Cancelar" onAction="#onCancelar" prefWidth="100" style="-fx-cursor:hand;"/>
        <Button text="Guardar" onAction="#onGuardar" defaultButton="true" prefWidth="100"
                style="-fx-background-color:#1976D2;-fx-text-fill:white;-fx-cursor:hand;-fx-font-weight:bold;"/>
    </HBox>

</VBox>